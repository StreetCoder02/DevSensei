# DevSensei — Environment Variables
# Copy this file: cp .env.example .env
# Then fill in your values. NEVER commit .env to git.

# ── Required ──────────────────────────────────
# Gemini API key — get it free from:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Server Configuration ──────────────────────────────────
# Server port (default: 3000)
PORT=3000

# Environment mode: development or production
NODE_ENV=production

# Health check response message
PING_MESSAGE="pong"

# ── Optional: Rate Limiting Configuration ──────────────────────────────────
# Rate limit window in milliseconds (default: 15000 = 15 seconds)
# Limits brute-force attacks on API endpoints
RATE_LIMIT_WINDOW_MS=15000

# Maximum requests allowed per window (default: 30 requests)
RATE_LIMIT_MAX_REQUESTS=30

# ── Optional: Gemini API Configuration ──────────────────────────────────
# Timeout for Gemini API calls in milliseconds (default: 30000 = 30 seconds)
# Prevents hanging requests if API is slow or unresponsive
API_TIMEOUT_MS=30000

